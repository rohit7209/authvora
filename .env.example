# Authvora Environment Configuration

# PostgreSQL
POSTGRES_USER=authvora
POSTGRES_PASSWORD=authvora_secret
POSTGRES_DB=authvora
POSTGRES_PORT=5432
DATABASE_URL=postgres://authvora:authvora_secret@localhost:5432/authvora?sslmode=disable

# Redis
REDIS_PASSWORD=authvora_redis
REDIS_PORT=6379
REDIS_URL=redis://:authvora_redis@localhost:6379/0

# Auth Service
AUTH_SERVICE_PORT=8081
JWT_ISSUER=authvora
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=168h

# API Gateway
API_GATEWAY_PORT=8080
AUTH_SERVICE_URL=http://localhost:8081
RISK_ENGINE_URL=http://localhost:8082
POLICY_ENGINE_URL=http://localhost:8083

# Risk Engine
RISK_ENGINE_PORT=8082

# Policy Engine
POLICY_ENGINE_PORT=8083

# MCP Server
MCP_SERVER_PORT=8084

# Google OAuth (fill in your own)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/api/v1/auth/oauth/google/callback

# Logging
LOG_LEVEL=debug
